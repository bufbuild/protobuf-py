{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["helpers:pinGitHubActionDigests", "schedule:earlyMondays"],
  prHourlyLimit: 0,
  lockFileMaintenance: {
    enabled: true,
  },
  packageRules: [
    {
      matchManagers: ["github-actions"],
      separateMajorMinor: false,
      groupName: "GitHub Actions",
    },
    {
      matchManagers: ["pep621"],
      matchDepTypes: ["project.dependencies", "project.optional-dependencies"],
      matchFileNames: ["pyproject.toml"],
      // We manage production dependencies ourselves, only bumping
      // when necessary.
      enabled: false,
    },
    {
      matchCategories: ["python"],
      groupName: "Python dependencies",
    },
    // protoc updates may need additional updates to docs or conformance tests
    {
      "matchCategories": ["python"],
      "matchPackageNames": ["protoc-runner"],
      "groupName": "protoc"
    },
    {
      matchCategories: ["rust"],
      groupName: "Rust dependencies",
      rangeStrategy: "bump",
    },
  ],
  customManagers: [
    {
      customType: "regex",
      fileMatch: ["^packages/protoc-runner/pyproject\\.toml$"],
      matchStrings: ['(?m)^version = "(?<currentValue>[^"]+)"'],
      datasourceTemplate: "github-releases",
      packageNameTemplate: "protocolbuffers/protobuf",
      extractVersionTemplate: "^v(?<version>.+)$",
      versioningTemplate: "loose",
    },
  ],
}
